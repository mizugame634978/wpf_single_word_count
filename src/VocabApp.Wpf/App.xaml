<Application x:Class="VocabApp.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VocabApp.Wpf.ViewModels"
             xmlns:views="clr-namespace:VocabApp.Wpf.Views"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type vm:WordListViewModel}">
                <views:WordListView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
