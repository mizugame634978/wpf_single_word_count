<Window x:Class="VocabApp.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VocabApp.Wpf.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}"
        Title="{Binding Title}"
        Height="640" Width="980"
        WindowStartupLocation="CenterScreen"
        FontFamily="Yu Gothic UI"
        Loaded="OnLoaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F3F3F3" Padding="12">
            <StackPanel>
                <TextBlock Text="VocabApp" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />
                <Button Content="単語一覧" HorizontalContentAlignment="Left" Margin="0,4"
                        BorderThickness="0" Background="Transparent"
                        Command="{Binding ShowWordListCommand}" />
                <TextBlock Text="テスト" Margin="4,8" Foreground="Gray" />
                <TextBlock Text="インポート / エクスポート" Margin="4,8" Foreground="Gray" />
                <TextBlock Text="設定" Margin="4,8" Foreground="Gray" />
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentContent}" />
    </Grid>
</Window>
