<Window x:Class="VocabApp.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VocabApp.Wpf.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=True}"
        Title="{Binding Title}"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Yu Gothic UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F3F3F3" Padding="12">
            <StackPanel>
                <TextBlock Text="VocabApp" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />
                <TextBlock Text="単語一覧" Margin="0,4" />
                <TextBlock Text="テスト" Margin="0,4" Foreground="Gray" />
                <TextBlock Text="インポート / エクスポート" Margin="0,4" Foreground="Gray" />
                <TextBlock Text="設定" Margin="0,4" Foreground="Gray" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="ようこそ" FontSize="28" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,12,0,0" Foreground="Gray"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
