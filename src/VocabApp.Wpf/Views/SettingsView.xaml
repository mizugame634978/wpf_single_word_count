<UserControl x:Class="VocabApp.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VocabApp.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             d:DesignHeight="500" d:DesignWidth="700"
             FontFamily="Yu Gothic UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="設定" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />

            <!-- テスト既定値 -->
            <TextBlock Text="テストの既定値" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,12">
                テスト設定画面を開いたときに最初に選ばれる値です。
            </TextBlock>

            <Grid Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="モード" VerticalAlignment="Center" Margin="0,4" />
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,4"
                          ItemsSource="{Binding Modes}"
                          SelectedItem="{Binding SelectedMode}"
                          DisplayMemberPath="Display" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="範囲" VerticalAlignment="Center" Margin="0,4" />
                <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,4"
                          ItemsSource="{Binding Ranges}"
                          SelectedItem="{Binding SelectedRange}"
                          DisplayMemberPath="Display" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="件数" VerticalAlignment="Center" Margin="0,4" />
                <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,4"
                          ItemsSource="{Binding Counts}"
                          SelectedItem="{Binding SelectedCount}"
                          Width="100" HorizontalAlignment="Left" />
            </Grid>

            <Button Content="設定を保存" HorizontalAlignment="Left" Padding="12,6"
                    Command="{Binding SaveCommand}" />

            <Separator Margin="0,24" />

            <!-- メンテナンス -->
            <TextBlock Text="メンテナンス" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />

            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8">
                DB の場所:
                <LineBreak />
                <Run Text="{Binding DbPath, Mode=OneWay}" />
            </TextBlock>
            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,12">
                ログの場所:
                <LineBreak />
                <Run Text="{Binding LogDir, Mode=OneWay}" />
            </TextBlock>

            <StackPanel Orientation="Horizontal">
                <Button Content="ログフォルダを開く" Padding="10,6" Margin="0,0,8,0"
                        Command="{Binding OpenLogFolderCommand}" />
                <Button Content="DB を初期化 (全データ削除)" Padding="10,6"
                        Command="{Binding ResetDatabaseCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}" Foreground="DarkSlateGray" Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
