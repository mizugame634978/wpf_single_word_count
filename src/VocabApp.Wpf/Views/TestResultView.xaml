<UserControl x:Class="VocabApp.Wpf.Views.TestResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VocabApp.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TestResultViewModel}"
             d:DesignHeight="500" d:DesignWidth="700"
             FontFamily="Yu Gothic UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="テスト結果" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />

        <Border Grid.Row="1" Background="#F0F4F8" Padding="20" CornerRadius="4" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock FontSize="32" FontWeight="Bold">
                    <Run Text="{Binding Correct, Mode=OneWay}" />
                    <Run Text=" / " />
                    <Run Text="{Binding Total, Mode=OneWay}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Bottom" Margin="16,0,0,6" FontSize="18">
                    <Run Text="正答率 " />
                    <Run Text="{Binding AccuracyPercent, Mode=OneWay, StringFormat=0.0}" />
                    <Run Text=" %" />
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="間違えた単語" FontWeight="SemiBold" Margin="0,0,0,8" />
            <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1">
                <DataGrid ItemsSource="{Binding WrongAnswers}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="単語" Binding="{Binding Word.Text}" Width="160" />
                        <DataGridTextColumn Header="正答" Binding="{Binding Word.Meaning}" Width="*" />
                        <DataGridTextColumn Header="あなたの回答" Binding="{Binding UserInput}" Width="200" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="間違いだけ再テスト" Width="160" Margin="0,0,8,0"
                    Padding="0,6"
                    Command="{Binding RetryWrongCommand}" />
            <Button Content="同じ範囲でもう一度" Width="160" Margin="0,0,8,0"
                    Padding="0,6"
                    Command="{Binding RetrySameCommand}" />
            <Button Content="設定に戻る" Width="120"
                    Padding="0,6"
                    Command="{Binding BackToSetupCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
