<UserControl x:Class="VocabApp.Wpf.Views.TestSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VocabApp.Wpf.ViewModels"
             xmlns:conv="clr-namespace:VocabApp.Wpf.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TestSessionViewModel}"
             d:DesignHeight="500" d:DesignWidth="700"
             FontFamily="Yu Gothic UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ヘッダ: 進捗 + 終了 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button DockPanel.Dock="Right"
                    Content="テスト終了"
                    Command="{Binding ExitCommand}"
                    Padding="12,4" />
            <TextBlock VerticalAlignment="Center">
                <Run Text="問題 " />
                <Run Text="{Binding CurrentQuestionNumber, Mode=OneWay}" FontWeight="Bold" />
                <Run Text=" / " />
                <Run Text="{Binding TotalQuestions, Mode=OneWay}" />
            </TextBlock>
        </DockPanel>

        <!-- 問題本文 -->
        <Border Grid.Row="1" Background="#F8F8F8" Padding="24" CornerRadius="4">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding PromptText}"
                           FontSize="32" FontWeight="SemiBold"
                           TextAlignment="Center" TextWrapping="Wrap"
                           HorizontalAlignment="Center" />

                <!-- 自己採点モードで露出した正解 -->
                <StackPanel Margin="0,16,0,0"
                            HorizontalAlignment="Center"
                            Visibility="{Binding IsAnswerRevealed, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                    <TextBlock Text="正解" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding AnswerRevealedText}"
                               FontSize="22" Foreground="DarkSlateGray"
                               TextAlignment="Center" TextWrapping="Wrap"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               Foreground="Gray" FontSize="12"
                               Visibility="{Binding UserInput, Converter={x:Static conv:NonEmptyStringToVisibilityConverter.Instance}}">
                        <Run Text="あなたの回答: " />
                        <Run Text="{Binding UserInput, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 操作領域 -->
        <ContentControl Grid.Row="2" Margin="0,16,0,0">
            <Grid>
                <!-- 入力欄 (タイピングモードかつ未公開時) -->
                <StackPanel Visibility="{Binding IsTypingInputVisible, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                    <TextBox Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="18" Padding="6"
                             VerticalContentAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SubmitCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="スキップ" Width="100" Margin="0,0,8,0"
                                Command="{Binding SkipCommand}" />
                        <Button Content="回答 (Enter)" Width="140"
                                Command="{Binding SubmitCommand}" IsDefault="True" />
                    </StackPanel>
                </StackPanel>

                <!-- 4 択 -->
                <ItemsControl ItemsSource="{Binding Choices}"
                              Visibility="{Binding IsMultipleChoiceMode, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" Rows="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Margin="4" Padding="12" FontSize="14"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding DataContext.SelectChoiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- フラッシュカード「答えを見る」 -->
                <Button Content="答えを見る" Padding="20,8" FontSize="14"
                        HorizontalAlignment="Center"
                        Command="{Binding RevealAnswerCommand}"
                        Visibility="{Binding IsRevealAnswerButtonVisible, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}" />

                <!-- 自己採点 (E→J タイピング・フラッシュカード共通) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="{Binding IsSelfGradeButtonsVisible, Converter={x:Static conv:BoolToVisibilityConverter.Instance}}">
                    <Button Content="× 不正解" Padding="20,10" Margin="4" FontSize="14"
                            Width="160"
                            Command="{Binding SelfGradeWrongCommand}" />
                    <Button Content="○ 正解" Padding="20,10" Margin="4" FontSize="14"
                            Width="160"
                            Command="{Binding SelfGradeCorrectCommand}"
                            IsDefault="True" />
                </StackPanel>
            </Grid>
        </ContentControl>

        <!-- 前問のステータス -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="DarkSlateGray" Margin="0,12,0,0" />
    </Grid>
</UserControl>
