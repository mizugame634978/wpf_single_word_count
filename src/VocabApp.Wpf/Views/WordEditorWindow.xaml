<Window x:Class="VocabApp.Wpf.Views.WordEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VocabApp.Wpf.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:WordEditorViewModel, IsDesignTimeCreatable=True}"
        Title="{Binding Title}"
        Height="520" Width="520"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Yu Gothic UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="単語 *" VerticalAlignment="Center" Margin="0,6" />
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,6"
                 Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="和訳 *" VerticalAlignment="Center" Margin="0,6" />
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6"
                 Text="{Binding Meaning, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="品詞" VerticalAlignment="Center" Margin="0,6" />
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,6"
                  ItemsSource="{Binding PartsOfSpeech}"
                  SelectedItem="{Binding SelectedPartOfSpeech}" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="例文" VerticalAlignment="Top" Margin="0,8" />
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,6"
                 AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                 Text="{Binding Example, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="メモ" VerticalAlignment="Top" Margin="0,8" />
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,6"
                 AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="5" Grid.Column="0" Text="タグ" VerticalAlignment="Center" Margin="0,6" />
        <TextBox Grid.Row="5" Grid.Column="1" Margin="0,6"
                 Text="{Binding TagsInput, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="セミコロン (;) またはカンマ (,) で区切る。例: toeic; verb" />

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="* は必須項目" Foreground="Gray" Margin="0,8,0,0" />

        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" Margin="0,0,8,0"
                    IsDefault="True"
                    IsEnabled="{Binding IsValid}"
                    Click="OnOkClick" />
            <Button Content="キャンセル" Width="80"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
